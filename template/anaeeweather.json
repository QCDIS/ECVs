                                "endTime": "2019-09-22T12:00:00.0000000+00:00",
                                "wkt": "POINT(10.904 44.304)",
                                "limit": "5",
                                "mode": "csv"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "null"
                    }
                }
            }
        },
