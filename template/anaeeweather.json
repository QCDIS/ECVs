        "/getNearestRasterData": {
            "post": {
                "tags": [
                    "wheater",
                    "Italy",
                    "raster",
                    "data"
                ],
                "summary": "getNearestRasterData",
                "description": "This API allows programmatic access to an extensive collection of historical weather series covering the whole Italian territory with 10 km resolution, starting from 1961.\nIt allows to retrieve data from the nearest known locations to a given geographical area of interest.",
                "operationId": "post-getnearestrasterdata",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/getNearestStations_CREA"
                            },
                            "example": {
                                "startTime": "2016-09-16T12:00:00.0000000+00:00",
                                "endTime": "2016-09-18T12:00:00.0000000+00:00",
                                "wkt": "POINT(10.904 44.304)",
                                "limit": "3",
                                "mode": "csv"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "null"
                    }
                }
            }
        },
        "/getNearestStationData": {
            "post": {
                "summary": "getNearestStationData",
                "description": "his API allows programmatic access to weather station data from a vast number of different sources our engineers took the hassle of integrating with each other.\nCREA does not gurantee this data to be complete, nor correct, nor on time.\nIt allows to retrieve data from the nearest known locations to a given geographical area of interest.",
                "operationId": "post-getneareststationdata",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/getNearestStations_CREA"
